<?xml version="1.0"?>
<ruleset name="Elementor Forge">
    <description>Elementor Forge coding standards — WPCS with PSR-4 reconciliation.</description>

    <file>elementor-forge.php</file>
    <file>uninstall.php</file>
    <file>src/</file>
    <file>tests/</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/fixtures/*</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="sp"/>

    <config name="minimum_supported_wp_version" value="6.4"/>
    <config name="testVersion" value="8.0-"/>

    <rule ref="WordPress">
        <!-- PSR-4 reconciliation — we use namespaced PascalCase filenames, not WP class-foo-bar.php. -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <!-- Short-form array syntax is fine in PHP 8+. -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
        <exclude name="WordPress.Arrays.ArrayDeclarationSpacing.AssociativeArrayFound"/>
        <!-- Yoda is anti-ergonomic; we rely on strict equality instead. -->
        <exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
        <!-- Namespaced hook names with slashes are idiomatic and readable. -->
        <exclude name="WordPress.NamingConventions.ValidHookName.UseUnderscores"/>
        <!-- Equals alignment is visually noisy; we skip the warning. -->
        <exclude name="WordPress.WhiteSpace.OperatorSpacing.NoSpaceBefore"/>
        <exclude name="Generic.Formatting.MultipleStatementAlignment.NotSameWarning"/>
        <!-- PHP 8 strict typing + descriptive names carry the docblock weight. -->
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamNameNoMatch"/>
        <exclude name="Squiz.Commenting.FunctionComment.IncorrectTypeHint"/>
        <exclude name="Squiz.Commenting.FunctionCommentThrowTag.Missing"/>
        <exclude name="Squiz.Commenting.VariableComment.Missing"/>
        <exclude name="Squiz.Commenting.ClassComment.Missing"/>
        <exclude name="Squiz.Commenting.FileComment.Missing"/>
        <exclude name="Squiz.Commenting.FileComment.MissingPackageTag"/>
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <exclude name="Generic.Commenting.DocComment.MissingShort"/>
        <exclude name="Generic.Commenting.DocComment.ShortNotCapital"/>
        <exclude name="Generic.Commenting.DocComment.LongNotCapital"/>
        <!-- The WordPress globals override sniff fires on local variables like $post_type or $post_id. -->
        <exclude name="WordPress.WP.GlobalVariablesOverride.Prohibited"/>
        <!-- mt_rand is fine for our non-security-sensitive ID generation; falling back only when CSPRNG fails. -->
        <exclude name="WordPress.WP.AlternativeFunctions.rand_mt_rand"/>
        <!-- Exceptions in our pure PHP path are programmer errors, not user output; escaping does not apply. -->
        <exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
        <!-- Get_posts with numberposts=-1 is the canonical pattern for uninstall and bulk ops. -->
        <exclude name="WordPress.WP.PostsPerPage.posts_per_page_numberposts"/>
        <!-- We do our own sanitization on top of this. -->
        <exclude name="WordPress.Security.ValidatedSanitizedInput.InputNotValidated"/>
    </rule>

    <rule ref="WordPress-Extra">
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="elementor-forge"/>
            </property>
        </properties>
    </rule>

    <!-- Teach the capabilities sniff about the WooCommerce shop-manager cap Phase 2 relies on. -->
    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="manage_woocommerce"/>
            </property>
        </properties>
    </rule>

    <rule ref="PHPCompatibilityWP"/>

    <!-- Tests do not need WPCS-style class/function docblocks; PSR-12 is enough. -->
    <rule ref="Squiz.Commenting.FunctionComment.Missing">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
    <rule ref="Squiz.Commenting.ClassComment.Missing">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
    <rule ref="Squiz.Commenting.FileComment.Missing">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
    <rule ref="WordPress.WP.AlternativeFunctions.file_system_operations_fwrite">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
    <!-- Bootstrap stubs WP core classes (WP_Error, wpdb) so unit tests can run without WP loaded.
         The wpdb stub class name is mandatory — it has to match WP's class exactly. The
         multiple-class-per-file warning fires for the same structural reason. -->
    <rule ref="Generic.Files.OneObjectStructurePerFile.MultipleFound">
        <exclude-pattern>tests/bootstrap.php</exclude-pattern>
    </rule>
    <rule ref="PEAR.NamingConventions.ValidClassName.StartWithCapital">
        <exclude-pattern>tests/bootstrap.php</exclude-pattern>
    </rule>
    <rule ref="WordPress.WP.AlternativeFunctions.json_encode_json_encode">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
    <rule ref="Generic.CodeAnalysis.UnusedFunctionParameter">
        <exclude-pattern>tests/bootstrap.php</exclude-pattern>
    </rule>
</ruleset>
